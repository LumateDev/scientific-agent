# ============================================
# Scientific Article Search Agent - Configuration
# ============================================

# --- Общие настройки ---
# Максимальное количество результатов на источник
MAX_RESULTS=20
# Таймаут HTTP-запросов (секунды)
REQUEST_TIMEOUT=30
# Количество повторных попыток при ошибке сети
MAX_RETRIES=3
# Задержка между повторными попытками (секунды)
RETRY_DELAY=2
# Задержка между запросами к одному источнику (секунды) — вежливость
POLITENESS_DELAY=1.0

# --- Пути ---
OUTPUT_DIR=./output
CACHE_DIR=./cache
LOG_DIR=./logs
PDF_DIR=./output/pdfs

# --- arXiv ---
# arXiv API бесплатный, ключ не требуется
ARXIV_ENABLED=true
ARXIV_BASE_URL=http://export.arxiv.org/api/query

# --- eLibrary.ru ---
ELIBRARY_ENABLED=false
ELIBRARY_BASE_URL=https://www.elibrary.ru

# --- Scopus (Elsevier) ---
# Получить ключ: https://dev.elsevier.com/
SCOPUS_ENABLED=false
SCOPUS_API_KEY=your_scopus_api_key_here
SCOPUS_BASE_URL=https://api.elsevier.com/content/search/scopus

# --- Web of Science (Clarivate) ---
# Получить доступ: https://developer.clarivate.com/
WOS_ENABLED=false
WOS_API_KEY=your_wos_api_key_here
WOS_BASE_URL=https://api.clarivate.com/apis/wos-starter/v1

# --- Перевод ---
# Варианты: google, yandex, none
TRANSLATOR=google
YANDEX_TRANSLATE_API_KEY=your_yandex_key_here

# --- Суммаризация ---
# Варианты: extractive, transformers
SUMMARIZER=extractive
# Количество предложений в резюме
SUMMARY_SENTENCES=5

# --- SQLite ---
DB_ENABLED=true
DB_PATH=./output/articles.db

# --- Web-интерфейс (Flask) ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Тема по умолчанию ---
DEFAULT_QUERY=dissociation recombination water
DEFAULT_QUERY_RU=влияние диссоциации рекомбинации молекул воды на процессы переноса ЭМС